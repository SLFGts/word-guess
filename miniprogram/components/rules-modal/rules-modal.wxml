<!--components/rules-modal/rules-modal.wxml-->
<!-- 规则说明弹窗 -->

<view class="modal-bg" bindtap="onClose">
  <view class="modal-card rules-modal" catchtap>
    <view class="modal-close" bindtap="onClose">×</view>
    <text class="modal-title">玩法规则</text>
    <text class="rules-desc">基于语义相似的 AI 猜词小游戏</text>
    <view class="rules-list">
      <view class="rule-item" wx:for="{{rules}}" wx:key="index">
        <text>{{index + 1}}. {{item.text || item}}</text>
      </view>
    </view>
    <!-- AI 幻觉提示 -->
    <view class="rules-warning">
      <text class="rules-warning-icon">⚠️</text>
      <text class="rules-warning-text"> AI 会产生幻觉，所有内容仅供参考</text>
    </view>
    <view class="rules-ok-row">
      <view class="doodle-button rules-ok-btn" bindtap="onClose">知道了 ✓</view>
    </view>
  </view>
</view>