/* components/rules-modal/rules-modal.wxss */
/* 规则说明弹窗样式 */

.rules-modal {
  text-align: center;
}

/* 弹窗标题（组件内补一份，确保样式在组件内生效） */
.modal-title {
  display: block;
  text-align: center;
  font-size: var(--text-3xl);
  font-weight: bold;
  margin: 6rpx 0 24rpx;
}

.rules-list {
  padding: var(--space-1);
  margin: var(--space-4) 0 var(--space-4);
  text-align: left;
  font-size: var(--text-md);
  line-height: 1.8;
}

.rule-item {
  padding: var(--space-3) 0;
  color: var(--color-text);
}

/* 游戏定位描述 */
.rules-desc {
  display: block;
  text-align: center;
  font-size: var(--text-md);
  color: var(--color-text-sub);
  margin: var(--space-3) 0 var(--space-5);
}

/* AI 幻觉警告 */
.rules-warning {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  margin: var(--space-3) 0 var(--space-5);
  padding: var(--space-3) var(--space-4);
  background: #FFF0E0;
  border: 3rpx dashed var(--color-primary);
  border-radius: var(--radius-lg);
}

.rules-warning-icon {
  font-size: var(--text-lg);
  flex-shrink: 0;
}

.rules-warning-text {
  font-size: var(--text-md);
  color: var(--color-orange-dark);
  font-weight: bold;
}

/* 知道了按钮：居中，缩小 */
.rules-ok-row {
  display: flex;
  justify-content: center;
}

.rules-ok-btn {
  padding: 16rpx 60rpx;
  font-size: var(--text-lg);
  background: var(--color-primary);
}