/* components/giveup-modal/giveup-modal.wxss */
/* 放弃结算弹窗样式 */

.giveup-modal {
  text-align: center;
}

.giveup-icon {
  font-size: 96rpx;    /* 原型 48px ×2，token 阶梯无 96rpx，保留 */
  display: block;
  margin-bottom: 20rpx;   /* 原型 10px ×2 */
}

.giveup-title {
  display: block;
  text-align: center;
  font-size: var(--text-3xl);   /* 原型 25px ×2 = 50rpx */
  font-weight: bold;
  color: var(--color-blue);
  margin-bottom: 10rpx;   /* 原型 5px ×2 */
}

.giveup-answer {
  display: block;
  font-size: 32rpx;    /* 原型 16px ×2，保留 */
  margin-bottom: 6rpx;   /* 原型 3px ×2 */
}

.giveup-word {
  color: var(--color-red-deep);
  font-weight: bold;
  font-size: 36rpx;    /* 原型 18px ×2，保留 */
}

.giveup-stats {
  display: block;
  color: var(--color-text-sub);
  font-size: var(--text-md);    /* 原型 14px ×2 = 28rpx */
  margin-bottom: 40rpx;   /* 原型 20px ×2 */
}

/* 按钮行：左右排列 */
.giveup-btn-row {
  display: flex;
  gap: var(--space-3);
  margin-top: 40rpx;
}

.giveup-btn {
  flex: 1;
  padding: 18rpx 0;
  font-size: var(--text-xl);
  text-align: center;
  border-radius: var(--radius-lg);
}

.doodle-button {
  background-color: var(--color-primary);
}

/* 返回首页按钮：虚线边框 */
.giveup-btn--home {
  border: 4rpx dashed var(--color-border);
  background: transparent;
  color: var(--color-text);
}
