/* components/giveup-modal/giveup-modal.wxss */
/* 放弃结算弹窗样式 */

.giveup-modal {
  text-align: center;
}

.giveup-icon {
  font-size: 96rpx;
  display: block;
  margin-bottom: 20rpx;
}

.giveup-title {
  display: block;
  text-align: center;
  font-size: 50rpx;
  font-weight: bold;
  color: #A3C4F3;
  margin-bottom: 10rpx;
}

.giveup-answer {
  display: block;
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.giveup-word {
  color: #FFB347;
  font-weight: bold;
  font-size: 36rpx;
}

.giveup-stats {
  display: block;
  color: #8A8578;
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.modal-ok {
  width: 100%;
  padding: 22rpx;
  font-size: 38rpx;
}

.giveup-home-btn {
  border: 4rpx dashed #3A3A3A;
  background: transparent;
  border-radius: 20rpx;
  padding: 16rpx 42rpx;
  font-size: 30rpx;
  color: #3A3A3A;
  margin-top: 20rpx;
}
