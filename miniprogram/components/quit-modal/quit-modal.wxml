<!--components/quit-modal/quit-modal.wxml-->
<!-- 放弃确认弹窗 -->

<view class="modal-bg" bindtap="onContinue">
  <view class="modal-card quit-modal" catchtap>
    <text class="quit-icon">🤔</text>
    <text class="quit-title">要放弃这一局吗？</text>
    <text class="quit-sub">当前已猜 {{guessCount}} 次，最高分 {{maxScoreDisplay}}%</text>
    <view class="quit-btn-row">
      <view class="quit-btn quit-btn--continue doodle-button" bindtap="onContinue">继续猜词 💪</view>
      <view class="quit-btn quit-btn--quit" bindtap="onQuit">放弃本局</view>
    </view>
  </view>
</view>
