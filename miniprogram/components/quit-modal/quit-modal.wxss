/* components/quit-modal/quit-modal.wxss */
/* 放弃确认弹窗样式 */

.quit-modal {
  text-align: center;
}

.quit-icon {
  font-size: 84rpx;
  display: block;
  margin-bottom: 14rpx;
}

.quit-title {
  display: block;
  text-align: center;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 14rpx;
}

.quit-sub {
  display: block;
  color: #8A8578;
  font-size: 28rpx;
  margin-bottom: 36rpx;
}

.modal-ok {
  width: 100%;
  padding: 22rpx;
  font-size: 38rpx;
}

.quit-btn {
  border: 4rpx solid #FF9EBB;
  background: transparent;
  border-radius: 20rpx;
  width: 100%;
  padding: 18rpx;
  margin-top: 26rpx;
  color: #3A3A3A;
  font-size: 32rpx;
}
