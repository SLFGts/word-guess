/* ====================================
   猜词小程序 — 轻松像素涂鸦风格全局样式
   ==================================== */

/* 加载自定义字体（HTTPS CDN） */
@font-face {
  font-family: "ZCOOL";
  src: url("https://cdn.jsdelivr.net/gh/SLFGts/word-guess@main/miniprogram/assets/fonts/ZCOOLKuaiLe-Regular.woff2");
  font-display: swap;
}

@font-face {
  font-family: "PressStart";
  src: url("https://cdn.jsdelivr.net/gh/SLFGts/word-guess@main/miniprogram/assets/fonts/PressStart2P-Regular.woff2");
  font-display: swap;
}

/* CSS 变量定义 */
page {
  --color-bg: #F5F0E1;          /* 暖米色背景 */
  --color-card: #FFF8EE;        /* 奶油色卡片 */
  --color-border: #3A3A3A;      /* 黑色描边 */
  --color-primary: #FFB347;     /* 暖橙强调色 */
  --color-pink: #FF9EBB;        /* 柔粉 */
  --color-green: #A8E6A3;       /* 薄荷绿 */
  --color-blue: #A3C4F3;        /* 天蓝 */
  --color-purple: #C9A8E8;      /* 淡紫 */
  --color-text: #3A3A3A;        /* 主文字色 */
  --color-text-sub: #8A8578;    /* 副文字色 */
  --color-shadow: #3A3A3A;      /* 阴影色 */

  background: var(--color-bg);
  color: var(--color-text);
  font-family: "ZCOOL", "PingFang SC", "Microsoft YaHei", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 像素字体类 */
.pixel {
  font-family: "PressStart", "Courier New", monospace;
  letter-spacing: -1rpx;
}

/* ====================================
   通用组件样式
   ==================================== */

/* 涂鸦卡片 */
.doodle-card {
  background: var(--color-card);
  border: 3rpx solid var(--color-border);
  border-radius: 18rpx;
  box-shadow: 6rpx 6rpx 0 var(--color-shadow);
}

/* 涂鸦按钮 */
.doodle-button {
  border: 3rpx solid var(--color-border);
  border-radius: 13rpx;
  box-shadow: 4rpx 4rpx 0 var(--color-shadow);
  color: var(--color-text);
  font-weight: 800;
  background: var(--color-primary);
  text-align: center;
  transition: transform 0.12s, box-shadow 0.12s;
}

.doodle-button:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 var(--color-shadow);
}

.doodle-button--disabled {
  opacity: 0.4;
  background: #E8E0D0;
}

/* 导航栏 */
.nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
  margin-bottom: 24rpx;
  font-size: 34rpx;
}

.nav-back {
  background: transparent;
  border: 0;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1;
  color: var(--color-text);
  padding: 0 10rpx;
}

/* 装饰星星 */
.star {
  position: absolute;
  color: var(--color-primary);
  font-family: "PressStart", monospace;
  animation: twirl 3s linear infinite;
}

/* 波浪线 */
.wave {
  color: var(--color-pink);
  letter-spacing: -8rpx;
  font-size: 40rpx;
  overflow: hidden;
  white-space: nowrap;
  margin: 40rpx 0;
}

/* ====================================
   弹窗样式
   ==================================== */

.modal-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 44rpx;
  background: rgba(0, 0, 0, 0.5);
  animation: fade 0.2s ease;
}

.modal-card {
  width: 100%;
  max-width: 720rpx;
  padding: 54rpx 44rpx 46rpx;
  background: var(--color-card);
  border: 3rpx solid var(--color-border);
  border-radius: 40rpx;
  box-shadow: 16rpx 16rpx 0 var(--color-shadow);
  animation: modal-up 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.modal-close {
  float: right;
  border: 0;
  background: transparent;
  color: var(--color-text-sub);
  font-size: 54rpx;
  line-height: 36rpx;
  padding: 0;
}

/* ====================================
   动画 Keyframes
   ==================================== */

@keyframes page-in {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: none; }
}

@keyframes twirl {
  to { transform: rotate(360deg); }
}

@keyframes fade {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes modal-up {
  from { opacity: 0; transform: translateY(40rpx) scale(0.95); }
  to { opacity: 1; transform: none; }
}

@keyframes pulse {
  50% { transform: scale(1.05); }
}

@keyframes slide-in {
  from { opacity: 0; transform: translateX(60rpx); }
  to { opacity: 1; transform: none; }
}

@keyframes confetti-fall {
  0% { transform: translateY(-100rpx) rotate(0deg); opacity: 1; }
  100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
}

/* ====================================
   页面容器
   ==================================== */

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 44rpx 40rpx 64rpx;
  animation: page-in 0.35s ease both;
  position: relative;
  overflow: hidden;
}
