<!--pages/index/index.wxml-->
<!-- 卡通刺猬风格首页：刺猬放大呼吸版
     结构：标题区(词踪+周围散落装饰) + 副标题+波浪 → 大刺猬(呼吸跳动) → 开始按钮+引导 → 双入口卡片
     保留刺猬为绝对主体；动效：刺猬呼吸 + 主按钮脉冲；装饰图案轻浮动 -->

<view class="page home-page">
  <!-- 标题区：词踪 + 副标题引导 + 波浪分隔
       装饰浮在标题四周（home-header 为 relative 定位参照） -->
  <view class="home-header">
    <!-- 装饰散布：像素图案，围绕标题紧密散落 -->
    <text class="deco deco-a">✦</text>
    <text class="deco deco-b">◆</text>
    <text class="deco deco-d">●</text>
    <text class="deco deco-e">✧</text>
    <text class="deco deco-f">◆</text>

    <view class="home-title">
      <text class="logo-guess">词</text>
      <text class="logo-word">踪</text>
    </view>
  </view>
  <text class="home-subtitle">循着语义的踪迹，</text>
  <text class="home-subtitle">找到藏起来的那个词。</text>
  <view class="wave home-wave">〰〰〰〰〰〰〰〰〰〰</view>

  <!-- 刺猬舞台：刺猬主体放大 + 呼吸跳动动效（去草地、去问号气泡） -->
  <view class="hedgehog-stage">
    <image class="hedgehog-img hedgehog-bounce" src="https://fenger-bucket.oss-cn-beijing.aliyuncs.com/word_guess/images/hedgehog.png" mode="aspectFit" />
  </view>

  <!-- 开始游戏主按钮（纯 bindtap 用 view，坑 4.9；引导语融入按钮内部） -->
  <view class="doodle-button start-button" bindtap="onQuickStart">
    <text class="start-main">开始游戏 <text class="pixel">▶</text></text>
    <text class="start-sub">点击开始一场猜词冒险~</text>
  </view>

  <!-- 底部双入口卡片 -->
  <view class="bottom-actions">
    <view class="action-btn" bindtap="onGoStats">
      <text class="action-icon">🏆</text>
      <text class="action-label">历史战绩</text>
    </view>
    <view class="action-btn" bindtap="onOpenRules">
      <text class="action-icon">📖</text>
      <text class="action-label">玩法规则</text>
    </view>
  </view>

  <!-- 角落像素装饰保留 -->
  <text class="star star-tl">✦</text>
  <text class="star star-tr">◆</text>
  <text class="star star-br"></text>
</view>

<!-- 规则弹窗：放在 .page 外层（坑 4.4：fixed 弹窗不能嵌在 overflow:hidden 的 .page 内） -->
<rules-modal wx:if="{{rulesOpen}}" bind:close="onCloseRules" />
