/* pages/game/game.wxss */
/* 轻松像素涂鸦风格游戏页：心流体验 */

.game-page {
  padding-top: 44rpx;
}

/* 顶部状态栏 */
.game-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.game-head-center {
  text-align: center;
  flex: 1;
}

.game-head-center text {
  display: block;
  font-size: 30rpx;
}

.game-head-center .pixel {
  font-size: 34rpx;
  color: #FFB347;
}

.game-mode {
  color: #8A8578;
  font-size: 22rpx;
  margin-top: 6rpx;
}

.tiny-stars {
  color: #C9A8E8;
  font-size: 30rpx;
}

/* 目标词字数提示 */
.target-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 26rpx 30rpx;
  box-shadow: 8rpx 8rpx 0 #3A3A3A;
  margin-bottom: 38rpx;
}

.target-icon {
  font-size: 58rpx;
}

.target-info {
  flex: 1;
}

.target-label {
  font-size: 24rpx;
  color: #8A8578;
  display: block;
}

.target-word {
  font-size: 40rpx;
  color: #3A3A3A;
}

.target-len {
  margin-left: auto;
  font-size: 22rpx;
  padding: 10rpx 16rpx;
  background: #FF9EBB;
  border: 4rpx solid #3A3A3A;
  border-radius: 16rpx;
}

/* 输入区 */
.guess-row {
  display: flex;
  gap: 16rpx;
  margin: 38rpx 0;
}

.guess-input {
  min-width: 0;
  flex: 1;
  border: 6rpx solid #3A3A3A;
  border-radius: 24rpx;
  padding: 22rpx 24rpx;
  font-size: 32rpx;
  background: #FFFFFF;
}

.guess-placeholder {
  color: #8A8578;
}

.guess-btn {
  padding: 0 28rpx;
  font-size: 36rpx;
}

/* 分数读数区 */
.score-card {
  padding: 32rpx 34rpx;
  box-shadow: 8rpx 8rpx 0 #3A3A3A;
}

.score-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.score-label {
  font-size: 28rpx;
  color: #3A3A3A;
}

.score-num {
  font-size: 50rpx;
  color: #75C875;
}

.score-num.hot {
  animation: pulse 1.6s infinite;
}

.score-pct {
  font-size: 26rpx;
  color: #8A8578;
}

.score-bar {
  height: 30rpx;
  border: 4rpx solid #3A3A3A;
  border-radius: 20rpx;
  background: #E6E0D3;
  overflow: hidden;
  margin-top: 20rpx;
}

.score-bar-fill {
  height: 100%;
  display: block;
  background: linear-gradient(90deg, #A8E6A3 20%, #FFB347 70%);
  border-radius: 16rpx;
  transition: width 0.6s ease;
}

.score-scale {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: #8A8578;
  margin-top: 10rpx;
}

.score-hint {
  display: block;
  text-align: center;
  font-size: 26rpx;
  font-weight: bold;
  margin-top: 12rpx;
}

/* 波浪线 */
.game-page > .wave {
  margin: 40rpx -40rpx 26rpx;
}

/* 猜测历史 */
.history-title {
  display: flex;
  justify-content: space-between;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 18rpx;
}

.history-sub {
  color: #8A8578;
  font-size: 22rpx;
}

.guess-list {
  display: grid;
  gap: 18rpx;
  max-height: 640rpx;
}

.guess-item {
  display: grid;
  grid-template-columns: 1fr auto 88rpx;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 22rpx;
  border-width: 4rpx;
  border-radius: 24rpx;
  box-shadow: 4rpx 4rpx 0 #3A3A3A;
  animation: slide-in 0.35s both;
}

.guess-item.best {
  background: #D4F5D0;
}

.guess-word {
  font-size: 30rpx;
  font-weight: bold;
}

.mini-bar {
  height: 18rpx;
  border: 2rpx solid #3A3A3A;
  border-radius: 10rpx;
  background: #E6E0D3;
  overflow: hidden;
  min-width: 120rpx;
}

.mini-bar-fill {
  height: 100%;
  display: block;
  border-radius: 8rpx;
}

.guess-score {
  font-size: 24rpx;
  color: #6F9FE4;
  text-align: right;
}

.guess-score.hot {
  color: #FF9E40;
  animation: pulse 1.6s infinite;
}

/* 提示面板 */
.hint-area {
  margin-top: 40rpx;
}

.hint-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.hint-buttons {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.hint-btn {
  flex: 1;
  padding: 16rpx 4rpx;
  font-size: 22rpx;
}

.hint-card {
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  box-shadow: 6rpx 6rpx 0 #3A3A3A;
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.hint-tag {
  background: #A3C4F3;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.hint-text {
  flex: 1;
}

/* 调试用：看答案 */
.debug-btn {
  margin: 30rpx auto 0;
  display: block;
  width: 60%;
  padding: 16rpx 0;
  background: transparent;
  border: 2rpx dashed #8A8578;
  border-radius: 16rpx;
  color: #8A8578;
  font-size: 24rpx;
}

.debug-area {
  margin-top: 30rpx;
  padding: 20rpx 24rpx;
  background: #FFF8EE;
  border: 2rpx dashed #FFB347;
  border-radius: 16rpx;
  text-align: center;
}

.debug-label {
  font-size: 24rpx;
  color: #8A8578;
}

.debug-word {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFB347;
  margin: 0 16rpx;
}

.debug-mode {
  font-size: 20rpx;
  color: #8A8578;
}

/* 加载遮罩 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(245, 240, 225, 0.85);
}

.loading-card {
  background: #FFF8EE;
  border: 3px solid #3A3A3A;
  border-radius: 20px;
  box-shadow: 6px 6px 0 #3A3A3A;
  padding: 40px 30px;
  text-align: center;
}

.loading-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 16px;
  animation: pulse 1.6s infinite;
}

.loading-text {
  font-size: 16px;
  color: #3A3A3A;
  font-weight: bold;
}
