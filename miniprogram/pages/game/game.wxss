/* pages/game/game.wxss */
/* 轻松像素涂鸦风格游戏页：心流体验 — 主次分明布局 */

/* 游戏页：custom 导航栏，顶部约束到胶囊按钮下方 */
.game-page {
  padding-top: var(--safe-top);
  padding-bottom: 180rpx;   /* 为底部固定操作栏预留空间 */
}

/* ========== 顶部信息栏 ========== */
.game-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  margin-bottom: var(--space-6);
}

.game-head-center {
  flex: 1;
  display: flex;
  justify-content: center;
}

/* 猜测次数：纯文字，无边框阴影 */
.guess-count-text {
  font-size: var(--text-lg);
  color: var(--color-text);
}

/* 猜测次数数字：橙色高亮 */
.guess-count-num {
  color: var(--color-primary);
}


/* 计时显示：无边框阴影 */
.timer-badge {
  font-size: var(--text-lg);
  color: var(--color-text);
  min-width: 120rpx;
  text-align: right;
}

/* ========== 英雄卡片：神秘目标词（视觉焦点） ========== */
.hero-card {
  background: var(--color-card);
  border: 8rpx dashed var(--color-border);
  border-radius: var(--radius-2xl);
  padding: 64rpx 40rpx;    /* 原型高度缩小20%：80→64 */
  text-align: center;
  position: relative;
  margin-bottom: var(--space-6);
  overflow: hidden;
}

/* 卡片内部装饰：淡色涂鸦元素 */
.hero-card::before {
  content: '✦ ☆ ✧';
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: var(--text-lg);
  color: var(--color-purple);
  opacity: 0.4;
  letter-spacing: 40rpx;
}

.hero-card::after {
  content: '☁ ✿ ☁';
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: var(--text-lg);
  color: var(--color-pink);
  opacity: 0.35;
  letter-spacing: 40rpx;
}

.hero-question-row {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: var(--space-4);
}

.hero-question {
  font-size: 115rpx;    /* 144rpx缩小20% */
  color: var(--color-border);
  display: inline-block;
  line-height: var(--leading-none);
}

.hero-sub {
  font-size: var(--text-lg);
  color: var(--color-text-sub);
  display: block;
}

/* 类别提示：直接展示在字数下方，低调醒目 */
.hero-category {
  font-size: var(--text-base);
  color: var(--color-primary);
  display: block;
  margin-top: 8rpx;
  line-height: var(--leading-tight);
}

/* ========== 输入区 ========== */
.guess-row {
  display: flex;
  gap: var(--space-3);
  margin-bottom: var(--space-5);
}

/* 输入框：圆角与 doodle-button 保持一致 */
.guess-input {
  flex: 7;
  min-width: 0;
  box-sizing: border-box;
  border: var(--border-w) solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 0 var(--space-5);
  font-size: var(--text-xl);
  background: var(--color-card);
  height: 72rpx;
}

/* 提问模式：输入框黄色高亮 */
.guess-input--question {
  border-color: var(--color-primary);
  background: var(--color-cream);
}

/* placeholder 垂直居中：重置默认间距，字体字号与提交按钮一致 */
.guess-placeholder {
  color: var(--color-text-sub);
  line-height: 72rpx;
  padding: 0;
  margin: 0;
  font-family: "ZCOOL", "PingFang SC", "Microsoft YaHei", "Helvetica Neue", sans-serif;
  font-size: var(--text-xl);
}

/* 提问模式：placeholder 黄色 */
.guess-placeholder--question {
  color: var(--color-orange-dark);
  line-height: 72rpx;
  padding: 0;
  margin: 0;
  font-family: "ZCOOL", "PingFang SC", "Microsoft YaHei", "Helvetica Neue", sans-serif;
  font-size: var(--text-xl);
}

/* ========== 提交按钮 ========== */
.submit-btn {
  flex: 3;
  font-size: var(--text-xl);
  background: var(--color-blue);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: var(--leading-tight);
  box-shadow: none;
}

/* 提问模式：按钮黄色 */
.submit-btn--question {
  background: var(--color-primary);
}

/* ========== 反馈提示文字 ========== */
.feedback-text {
  display: block;
  text-align: center;
  font-size: var(--text-lg);
  font-weight: bold;
  margin-bottom: var(--space-6);
}

/* 提问模式提示文字 */
.feedback-text--question {
  color: var(--color-primary);
  font-weight: normal;
  margin-bottom: var(--space-4);
}

/* ========== 猜测历史（进度条形式，默认展示前3条） ========== */
.history-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3);
}

.history-title {
  font-size: var(--text-lg);
  font-weight: bold;
  color: var(--color-text);
}

.history-more {
  font-size: var(--text-sm);
  color: var(--color-link);
}

.guess-list {
  display: flex;
  flex-direction: column;
  max-height: 320rpx;
}

.guess-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  margin: 0 var(--space-2) var(--space-2) 0;
  background: var(--color-card);
  border: var(--border-w) solid var(--color-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-xs);
  animation: slide-in 0.35s both;
}

.guess-word {
  font-size: var(--text-lg);
  font-weight: bold;
  min-width: 80rpx;
  flex-shrink: 0;
  margin-right: var(--space-3);
}

/* 进度条轨道 */
.guess-bar-track {
  flex: 1;
  height: 20rpx;
  border: 4rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-bar-track);
  overflow: hidden;
  margin-right: var(--space-3);
}

/* 进度条填充 */
.guess-bar-fill {
  height: 100%;
  display: block;
  border-radius: var(--radius-sm);
  transition: width 0.5s var(--ease-out-quint);
}

.guess-score {
  font-size: var(--text-base);
  font-weight: bold;
  text-align: right;
  min-width: 72rpx;
  flex-shrink: 0;
}

/* ========== 完整记录弹窗 ========== */
.history-modal {
  max-height: 700rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.history-modal-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: var(--space-4);
  flex-shrink: 0;
}

.history-modal-head-left {
  flex: 1;
}

.history-modal-title {
  font-size: var(--text-2xl);
  font-weight: bold;
  display: block;
  line-height: var(--leading-tight);
}

.history-modal-sub {
  font-size: var(--text-sm);
  color: var(--color-text-sub);
  margin-top: 6rpx;
  display: block;
}

.history-modal-close {
  font-size: var(--text-2xl);
  font-weight: bold;
  color: var(--color-text-sub);
  line-height: 1;
  padding: 8rpx;
  flex-shrink: 0;
}

.history-modal-list {
  flex: 1;
  overflow-y: auto;
}

.history-row {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  margin: 0 var(--space-2) var(--space-2) 0;
  background: var(--color-card);
  border: var(--border-w) solid var(--color-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-xs);
  animation: slide-in 0.3s both;
}

.history-rank {
  font-size: var(--text-sm);
  color: var(--color-text-sub);
  min-width: 44rpx;
  flex-shrink: 0;
}

.history-rword {
  font-size: var(--text-lg);
  font-weight: bold;
  min-width: 80rpx;
  flex-shrink: 0;
}

.history-bar-track {
  flex: 1;
  height: 20rpx;
  border: 4rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-bar-track);
  overflow: hidden;
  margin: 0 var(--space-2);
}

.history-bar-fill {
  height: 100%;
  display: block;
  border-radius: var(--radius-sm);
  transition: width 0.5s var(--ease-out-quint);
}

.history-rscore {
  font-size: var(--text-base);
  font-weight: bold;
  text-align: right;
  min-width: 72rpx;
  flex-shrink: 0;
}

/* ========== 底部操作栏 ========== */
.bottom-bar {
  display: flex;
  gap: var(--space-3);
  margin-top: var(--space-6);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx calc(48rpx + var(--safe-bottom));
  background: var(--color-bg);
  z-index: 10;
}

.action-btn {
  flex: 1;
  padding: 22rpx 0;
  font-size: var(--text-xl);
  text-align: center;
  line-height: var(--leading-tight);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
}

.action-btn--hint {
  background: var(--color-primary);
  position: relative;
}

.action-btn--quit {
  background: var(--color-pink);
}

/* 提示剩余次数角标 */
.hint-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: var(--color-green-deep);
  color: var(--color-on-accent);
  font-size: var(--text-base);
  font-weight: bold;
  width: 45rpx;
  height: 45rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid var(--color-green-deep);
  line-height: 1;
}

/* ========== 提示内容卡片（与 guess-item 样式统一，圆角 radius-lg） ========== */
.hint-card {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  margin: 0 var(--space-2) var(--space-2) 0;
  background: var(--color-card);
  border: var(--border-w) solid var(--color-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-xs);
  animation: slide-in 0.35s both;
}

.hint-tag {
  background: var(--color-blue);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-xs);
  font-size: var(--text-sm);
  font-weight: bold;
  flex-shrink: 0;
}

.hint-text {
  flex: 1;
  line-height: var(--leading-snug);
}

/* ========== 加载遮罩（正方形卡片 + 外部模糊） ========== */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  animation: fade 0.2s ease;
}

/* 正方形加载卡片 */
.loading-card {
  width: 320rpx;
  height: 320rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--color-card);
  border: var(--border-w) solid var(--color-border);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-xl);
  padding: var(--space-6);
  text-align: center;
  box-sizing: border-box;
}

.loading-icon {
  font-size: 96rpx;
  display: block;
  margin-bottom: var(--space-4);
  animation: bounce 1s ease-in-out infinite;
}

.loading-text {
  font-size: var(--text-lg);
  color: var(--color-text);
  font-weight: bold;
  animation: fade 1.2s ease-in-out infinite alternate;
}
