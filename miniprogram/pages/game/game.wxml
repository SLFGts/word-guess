<!--pages/game/game.wxml-->
<!-- 轻松像素涂鸦风格游戏主界面：心流体验 -->

<!-- 用 page-container 包裹整个页面内容，拦截侧滑手势/物理返回键/navigateBack -->
<page-container
  show="{{swipeBackIntercept}}"
  overlay="{{false}}"
  duration="0"
  custom-style="height:100vh;overflow:scroll;background:var(--color-bg, #F5F0E1)"
  bind:beforeleave="onSwipeBackBeforeLeave"
  bind:afterleave="onSwipeBackAfterLeave">

  <view class="page game-page" style="--safe-top:{{safeTop}}px">
    <!-- 顶部信息栏：猜测次数 + 计时 -->
    <view class="game-head">
      <view class="nav-back" bindtap="onOpenQuit">←</view>
      <view class="game-head-center">
        <text class="guess-count-text">第 <text class="pixel guess-count-num">{{guessCount}}</text> 次猜测</text>
      </view>
      <view class="timer-badge">
        <text class="pixel">{{timeDisplay}}</text>
      </view>
    </view>

    <!-- 英雄卡片：神秘目标词（视觉焦点） -->
    <view class="hero-card">
      <view class="hero-question-row">
        <text class="hero-question pixel" wx:for="{{wordLen}}" wx:key="index">?</text>
      </view>
      <text class="hero-sub pixel">{{wordLen}}个字</text>
      <text class="hero-category pixel" wx:if="{{t1}}">{{t1}}</text>
    </view>

    <!-- 输入区 + 提交按钮(同一行 7:3) -->
    <view class="guess-row">
      <input class="guess-input {{askingQuestion ? 'guess-input--question' : ''}}"
             value="{{word}}"
             bindinput="onInput"
             bindconfirm="{{askingQuestion ? 'onAsk' : 'onGuess'}}"
             placeholder="{{askingQuestion ? '您有一次提问机会...' : '输入你的猜测...'}}"
             placeholder-class="{{askingQuestion ? 'guess-placeholder--question' : 'guess-placeholder'}}"
             confirm-type="done" />
      <view class="submit-btn doodle-button {{askingQuestion ? 'submit-btn--question' : ''}}"
            bindtap="{{askingQuestion ? 'onAsk' : 'onGuess'}}">
        {{askingQuestion ? '提问' : '提交'}}
      </view>
    </view>

    <!-- 提问模式提示文字 -->
    <text class="feedback-text feedback-text--question" wx:if="{{askingQuestion}}">
      请输入你的问题，或再次点击「提示」取消提问
    </text>

    <!-- 猜测历史列表（进度条，仅展示前3条） -->
    <view class="history-head" wx:if="{{guesses.length > 0}}">
      <view class="history-title">
        <text>猜测记录</text>
      </view>
      <view class="history-more" bindtap="onOpenHistory">
        <text>完整记录 →</text>
      </view>
    </view>

    <scroll-view class="guess-list" scroll-y enhanced enable-flex wx:if="{{guesses.length > 0}}">
      <view class="guess-item"
            wx:for="{{top3Guesses}}" wx:key="word"
            style="animation-delay: {{(index || 0) * 0.05}}s">
        <text class="guess-word pixel">{{item.word}}</text>
        <view class="guess-bar-track">
          <view class="guess-bar-fill" style="width:{{item.score || 0}}%;background:{{item.barColor || '#FFB347'}};"></view>
        </view>
        <text class="guess-score pixel" style="color:{{item.barColor || '#FFB347'}};">{{item.scoreDisplay || '0.00'}}%</text>
      </view>
    </scroll-view>

    <!-- 底部操作栏：提示 + 放弃 -->
    <view class="bottom-bar">
      <view class="doodle-button action-btn action-btn--hint" bindtap="onHint">
        <text> 提示</text>
        <text class="hint-badge" wx:if="{{!t2Used || !t3Used || !qa}}">{{3 - (t2Used ? 1 : 0) - (t3Used ? 1 : 0) - (qa ? 1 : 0)}}</text>
      </view>
      <view class="doodle-button action-btn action-btn--quit" bindtap="onOpenQuit"> 放弃</view>
    </view>

    <!-- 提示内容展示（依次追加） -->
    <view wx:if="{{hints.length > 0}}">
      <view class="history-head">
        <view class="history-title"><text>提示</text></view>
      </view>
      <scroll-view class="guess-list" scroll-y enhanced enable-flex wx:if="{{hints.length > 3}}">
        <view class="hint-card" wx:for="{{hints}}" wx:key="index">
          <text class="hint-tag">{{item.type}}</text>
          <text class="hint-text">{{item.text}}</text>
        </view>
      </scroll-view>
      <view class="guess-list" wx:else>
        <view class="hint-card" wx:for="{{hints}}" wx:key="index">
          <text class="hint-tag">{{item.type}}</text>
          <text class="hint-text">{{item.text}}</text>
        </view>
      </view>
    </view>

    <!-- 加载遮罩 -->
    <view class="loading-overlay" wx:if="{{loading}}">
      <view class="loading-card">
        <text class="loading-icon">⏳</text>
        <text class="loading-text">{{loadingText}}</text>
      </view>
    </view>
  </view>

</page-container>

<!-- 放弃确认弹窗：放在 .page 外部，避免 overflow:hidden 导致 fixed 定位失效 -->
<quit-modal wx:if="{{quitOpen}}"
            guessCount="{{guessCount}}"
            maxScore="{{maxScore}}"
            bind:continue="onCloseQuit"
            bind:quit="onConfirmQuit" />

<!-- 放弃结算弹窗：放在 .page 外部，避免 overflow:hidden 导致 fixed 定位失效 -->
<giveup-modal wx:if="{{giveupOpen}}"
              targetWord="{{giveupTarget}}"
              guessCount="{{guessCount}}"
              maxScore="{{giveupMaxScore}}"
              bind:playAgain="onGiveupPlayAgain"
              bind:goHome="onGiveupGoHome" />

<!-- 完整猜测记录弹窗：放在 .page 外部 -->
<view class="modal-bg" wx:if="{{historyOpen}}" bindtap="onCloseHistory">
  <view class="modal-card history-modal" catchtap>
    <view class="history-modal-head">
      <view class="history-modal-head-left">
        <text class="history-modal-title">完整猜测记录</text>
        <text class="history-modal-sub">按时间倒序</text>
      </view>
      <text class="history-modal-close" bindtap="onCloseHistory">✕</text>
    </view>
    <scroll-view class="history-modal-list" scroll-y enhanced>
      <view class="history-row" wx:for="{{sortedGuesses}}" wx:key="word" style="animation-delay: {{(index || 0) * 0.03}}s">
        <text class="history-rank pixel">#{{index + 1}}</text>
        <text class="history-rword pixel">{{item.word}}</text>
        <view class="history-bar-track">
          <view class="history-bar-fill" style="width:{{item.score || 0}}%;background:{{item.barColor || '#FFB347'}};"></view>
        </view>
        <text class="history-rscore pixel" style="color:{{item.barColor || '#FFB347'}};">{{item.scoreDisplay || '0.00'}}%</text>
      </view>
    </scroll-view>
  </view>
</view>
