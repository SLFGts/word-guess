/* pages/result/result.wxss */
/* 轻松像素涂鸦风格结算页 */

.result-page {
  text-align: center;
  padding-top: 88rpx;
}

/* 顶部彩带装饰 */
.confetti {
  color: #FF9EBB;
  font-size: 36rpx;
  letter-spacing: 16rpx;
  animation: twirl 6s linear infinite;
  margin-bottom: 20rpx;
}

/* 庆祝标题 */
.result-title {
  font-size: 84rpx;
  color: #F49C2A;
  margin: 20rpx 0 6rpx;
  transform: rotate(-2deg);
  font-weight: 900;
}

.result-sub {
  font-size: 26rpx;
  color: #8A8578;
  margin: 0 0 34rpx;
}

/* 目标词卡片 */
.word-cards {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.word-card {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 140rpx;
  border: 6rpx solid #3A3A3A;
  border-radius: 30rpx;
  box-shadow: 10rpx 10rpx 0 #3A3A3A;
  color: #FFFFFF;
  font-size: 64rpx;
  font-family: "PressStart", monospace;
  animation: modal-up 0.4s both;
}

.word-card-1 {
  background: #FF9EBB;
}

.word-card-2 {
  background: #87CA87;
  animation-delay: 0.12s;
}

/* 成绩卡片 */
.result-card {
  padding: 34rpx 30rpx;
  text-align: left;
}

.result-card-title {
  display: block;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 26rpx;
}

/* 四宫格 */
.result-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  margin: 26rpx 0;
  border: 2rpx dashed #8A8578;
}

.metric {
  padding: 26rpx 10rpx;
  text-align: center;
  border: 2rpx dashed #8A8578;
}

.metric-num {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
}

.metric-label {
  font-size: 22rpx;
  color: #8A8578;
  display: block;
  margin-top: 6rpx;
}

/* 趣味评价 */
.praise {
  border: 4rpx dashed #FFB347;
  border-radius: 20rpx;
  padding: 14rpx;
  text-align: center;
  color: #E38B1E;
  font-size: 32rpx;
  font-weight: bold;
  margin: 20rpx 0;
}

/* 分数曲线图 */
.path {
  margin-top: 30rpx;
  border-top: 4rpx dashed #D7CDBB;
  padding-top: 20rpx;
}

.path-title {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.path-sub {
  font-size: 20rpx;
  color: #8A8578;
}

.score-chart {
  width: 100%;
  height: 156rpx;
}

/* 主按钮 */
.result-primary {
  width: 76%;
  padding: 26rpx;
  margin: 50rpx auto 28rpx;
  font-size: 44rpx;
}

/* 返回按钮 */
.return-button {
  border: 4rpx dashed #3A3A3A;
  background: transparent;
  border-radius: 20rpx;
  padding: 16rpx 42rpx;
  font-size: 30rpx;
  color: #3A3A3A;
}
