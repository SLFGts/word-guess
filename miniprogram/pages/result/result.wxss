/* pages/result/result.wxss */
/* 轻松像素涂鸦风格结算页 */

/* 结算页：custom 导航栏，顶部约束到胶囊按钮下方 */
.result-page {
  text-align: center;
  padding-top: var(--space-4);
}

/* 顶部彩带装饰：原型无 margin-bottom，增强为呼吸闪烁效果 */
.confetti {
  color: var(--color-pink);
  font-size: 36rpx;     /* 原型 18px ×2，token 阶梯无 36rpx，保留 */
  letter-spacing: 16rpx;   /* 原型 8px ×2 */
  animation: shimmer 3s ease-in-out infinite;   /* 呼吸闪烁+字距扩缩，庆祝感 */
}

/* 庆祝标题 */
.result-title {
  font-size: var(--text-5xl);    /* 原型 42px ×2 = 84rpx */
  color: var(--color-orange-deep);
  margin: 20rpx 0 6rpx;    /* 原型 10px 0 3px ×2 */
  transform: rotate(-2deg);
  font-weight: 900;
}

.result-sub {
  font-size: 26rpx;    /* 原型 13px ×2，保留 */
  color: var(--color-text-sub);
  margin: 0 0 34rpx;   /* 原型 0 0 17px ×2 */
}

/* 目标词卡片 */
.word-cards {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;          /* 多字目标词换行防溢出 */
  gap: 24rpx;              /* 此处非 scroll-view，gap 安全（坑4.2 仅限 scroll-view 内） */
  margin-bottom: 48rpx;   /* 原型 24px ×2 */
}

.word-card {
  display: flex;
  align-items: center;      /* 垂直居中 */
  justify-content: center;  /* 水平居中 */
  width: 112rpx;            /* 原型 66px ×2 ×0.8，与 height 等宽成正方形 */
  height: 112rpx;           /* 原型 70px ×2 ×0.8 */
  line-height: 112rpx;      /* 抵消全局 line-height:1.5 撑开，确保 flex 居中不偏 */
  border: var(--border-w) solid var(--color-border);
  border-radius: 24rpx;     /* 原型 15px ×2 ×0.8 */
  box-shadow: 8rpx 8rpx 0 var(--color-shadow);  /* 原型 5px ×2 ×0.8 */
  color: var(--color-on-accent);
  font-size: 51rpx;         /* 原型 32px ×2 ×0.8 */
  font-family: "PressStart", monospace;
  animation: modal-up 0.5s var(--ease-out-back) both;
}

/* 4 色循环：原型仅示例 2 字（粉/绿），扩展为 4 色以支持任意字数目标词 */
.word-card-1 { background: var(--color-pink); }
.word-card-2 { background: var(--color-green-mid); }   /* 原型 #87ca87 */
.word-card-3 { background: var(--color-blue); }
.word-card-4 { background: var(--color-purple); }

/* 成绩卡片 */
.result-card {
  padding: var(--space-5) 30rpx;   /* 原型 17px 15px ×2，17px 走 --space-5 */
  text-align: left;
}

.result-card-title {
  display: block;
  text-align: center;
  font-size: var(--text-xl);    /* 原型 17px ×2 = 34rpx */
  font-weight: bold;
}

/* 四宫格 */
.result-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  margin: 30rpx 0;   /* 原型 13px ×2，微增增强呼吸感 */
  border: 4rpx dashed var(--color-text-sub);   /* 原型 1px ×2，加粗增强分隔感 */
}

.metric {
  padding: 28rpx 10rpx;   /* 原型 13px 5px ×2，上下微增 */
  text-align: center;
  border: 4rpx dashed var(--color-text-sub);   /* 原型 1px ×2，加粗增强 */
}

.metric-num {
  display: block;
  font-size: var(--text-2xl);   /* 原型 20px ×2 = 40rpx */
  font-weight: bold;
}

.metric-label {
  font-size: var(--text-sm);   /* 原型 11px ×2 = 22rpx */
  color: var(--color-text-sub);
  display: block;
  margin-top: 6rpx;   /* 原型 3px ×2 */
}

/* 趣味评价：原型 border:2px dashed, radius:10px, padding:7px, font-size:16px, 无 margin 无 bold */
.praise {
  border: 4rpx dashed var(--color-primary);   /* 原型 2px ×2 */
  border-radius: var(--radius-md);            /* 原型 10px ×2 = 20rpx */
  padding: 14rpx;    /* 原型 7px ×2 */
  text-align: center;
  color: var(--color-orange-dark);
  font-size: 32rpx;    /* 原型 16px ×2，保留 */
  background: var(--color-cream);   /* 奶油底增强视觉层次 */
  margin-top: 20rpx;   /* 与上方网格拉开间距 */
}

/* 分数曲线图 */
.path {
  margin-top: 30rpx;   /* 原型 15px ×2 */
  border-top: 4rpx dashed var(--color-path-line);   /* 原型 2px ×2 */
  padding-top: 20rpx;   /* 原型 10px ×2 */
  padding-bottom: 20rpx;   /* 增加底部边距 */
}

/* 逼近路径标题：原型仅"逼近路径"由 <b> 加粗 */
.path-title {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;    /* 原型 13px ×2，保留 */
  margin-bottom: 10rpx;   /* 原型 5px ×2 */
}

.path-sub {
  font-size: 20rpx;    /* 原型 10px ×2，保留 */
  color: var(--color-text-sub);
}

.chart-scroll {
  white-space: nowrap;
  width: 100%;
  height: 280rpx;
}

.score-chart {
  display: block;
  height: 280rpx;
}

/* 底部按钮容器：左右并排，等宽等高 */
.result-actions {
  display: flex;
  gap: var(--space-3);   /* 原型约 10px ×2 = 20rpx，走 --space-3 */
  margin: 50rpx var(--space-5) 28rpx;   /* 原型 25px auto 14px ×2，左右留安全边距 */
}

/* 主按钮（再来一局）：原型 width:76%; background:#ffb347; padding:13px; font-size:22px
   改为 flex:1 等分，与返回按钮等高 */
.result-primary {
  flex: 1;
  padding: 26rpx;    /* 原型 13px ×2 */
  background: var(--color-primary);
  font-size: 36rpx;    /* 统一字号，与返回按钮一致 */
  margin: 0;           /* 清除旧 margin: auto，由 flex 容器控制 */
}

/* 返回按钮：原型 border:2px dashed, radius:10px, padding:8px 21px, font-size:15px
   改为 flex:1 等分，与主按钮等高 */
.return-button {
  flex: 1;
  border: 4rpx dashed var(--color-border);   /* 原型 2px ×2 */
  background: transparent;
  border-radius: var(--radius-lg);            /* 与 doodle-button 统一圆角 */
  padding: 26rpx;    /* 与主按钮一致 padding，保证等高 */
  font-size: 36rpx;    /* 统一字号 */
  font-weight: 800;    /* 与 doodle-button 统一字重 */
  color: var(--color-text);
  text-align: center;
  transition: background 0.12s, color 0.12s;
}

/* 返回按钮按压态：虚线边框内填充底色，形成「实」感反馈 */
.return-button:active {
  background: var(--color-card);
  color: var(--color-primary);
}
