<!--pages/result/result.wxml-->
<!-- 轻松像素涂鸦风格结算庆祝页 -->

<view class="page result-page" style="--safe-top:{{safeTop}}px">
  <!-- 顶部庆祝装饰 -->
  <view class="confetti">✦ ◆ ✦ ◆ ✦</view>

  <!-- 庆祝标题 -->
  <view class="result-title">🎉 猜中啦！</view>

  <!-- 目标词卡片：逐字渲染，4 色循环（支持任意字数目标词） -->
  <view class="word-cards">
    <view class="word-card word-card-{{(index % 4) + 1}}"
          wx:for="{{targetChars}}" wx:key="*this"
          style="animation-delay: {{index * 0.06}}s">{{item}}</view>
  </view>

  <!-- 中央成绩卡片 -->
  <view class="result-card doodle-card">
    <view class="result-card-title">📊 本场成绩</view>

    <!-- 四宫格数据 -->
    <view class="result-grid">
      <view class="metric">
        <text class="metric-num pixel" style="color:var(--color-primary)">{{guessCount}}</text>
        <text class="metric-label">次猜测</text>
      </view>
      <view class="metric">
        <text class="metric-num pixel" style="color:var(--color-green-deep)">{{maxScoreDisplay}}%</text>
        <text class="metric-label">最高相似度</text>
      </view>
      <view class="metric">
        <text class="metric-num pixel" style="color:var(--color-blue-deep)">{{totalTime}}</text>
        <text class="metric-label">总用时</text>
      </view>
      <view class="metric">
        <text class="metric-num pixel" style="color:var(--color-pink)">{{hintUsed}}</text>
        <text class="metric-label">使用提示</text>
      </view>
    </view>

    <!-- 趣味评价 -->
    <view class="praise">{{praise}}</view>

    <!-- 分数曲线图（Canvas 替代 SVG），支持水平滚动 -->
    <view class="path">
      <view class="path-title">
        <text style="font-weight:bold">逼近路径</text>
      </view>
      <scroll-view scroll-x enable-flex class="chart-scroll">
        <canvas type="2d" id="scoreChart" class="score-chart" style="width:{{chartWidth}}px"></canvas>
      </scroll-view>
    </view>
  </view>

  <!-- 底部操作按钮：左右并排，等宽等高 -->
  <view class="result-actions">
    <view class="doodle-button result-primary" bindtap="onPlayAgain">再来一局 ▶</view>
    <view class="return-button" bindtap="onGoHome">返回首页 🏠</view>
  </view>
</view>
